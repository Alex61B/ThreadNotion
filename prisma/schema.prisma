generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SalesSkill {
  discovery_questions
  objection_handling
  product_knowledge
  closing
  storytelling
  empathy
}

enum SimulationMode {
  generic
  adaptive
  drill
  mixed_practice
}

enum TurnKind {
  FREE_TEXT
  MCQ
  WORD_BANK
}

enum TrendDirection {
  improving
  declining
  stable
}

enum TeamMemberRole {
  manager
  rep
}

enum TrainingAssignmentType {
  drill
  adaptive
}

/// Global account type (not the same as TeamMemberRole, which is membership in a team).
enum AccountRole {
  MANAGER
  SALES_REP
}

/// Phase 8: multi-user team training (opaque userId strings, same as Conversation.userId).
model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  members       TeamMember[]
  assignments   TrainingAssignment[]
  billingAccount BillingAccount?

  @@index([ownerId])
}

model TeamMember {
  id           String         @id @default(cuid())
  teamId       String
  userId       String
  role         TeamMemberRole @default(rep)
  displayName  String?
  joinedAt     DateTime       @default(now())
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TrainingAssignment {
  id              String                 @id @default(cuid())
  teamId          String
  assignedBy      String
  targetUserId    String?
  skill           SalesSkill
  assignmentType  TrainingAssignmentType
  active          Boolean                @default(true)
  createdAt       DateTime               @default(now())
  team            Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([targetUserId])
  @@index([teamId, active])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  title       String
  description String?
  brand       String?
  attributes  Json?
  price       Float?
  currency    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  scripts     Script[]
}

model Persona {
  id            String         @id @default(cuid())
  name          String         @unique
  tone          String?
  values        String?
  instructions  String
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  scripts       Script[]
}

model Conversation {
  id         String      @id @default(cuid())
  personaId  String
  userId     String?     // Links conversation to a specific user (anonymous UUID from localStorage)
  simulationMode SimulationMode @default(generic)
  /// Persisted adaptive scenario plan (set once on adaptive create when weaknesses exist). Null for generic or legacy rows.
  adaptiveScenarioPlan Json?
  /// Persisted drill plan (focused practice). Null for non-drill rows.
  drillPlan Json?
  /// Phase 10: cooldown / dedupe for optional live coaching tips (JSON blob).
  liveCoachingMeta Json?
  createdAt  DateTime    @default(now())
  persona    Persona     @relation(fields: [personaId], references: [id])
  evaluation Evaluation?
  messages   Message[]
  skillScores SimulationSkillScore[]
  evaluationSummary SimulationEvaluationSummary?

  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  turnKind       TurnKind     @default(FREE_TEXT)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  turnInteraction  TurnInteraction?
}

model TurnInteraction {
  id         String   @id @default(cuid())
  messageId  String   @unique
  challenge  Json
  response   Json?
  isCorrect  Boolean?
  score      Int?
  feedback   String?
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id             String       @id @default(cuid())
  conversationId String       @unique
  storytelling   Int
  emotional      Int
  persuasion     Int
  productKnow    Int
  total          Int
  strengths      String
  tips           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Script {
  id        String   @id @default(cuid())
  productId String
  personaId String?
  tone      String?
  content   Json
  cacheKey  String   @unique
  createdAt DateTime @default(now())
  persona   Persona? @relation(fields: [personaId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

/// Lightweight multi-session training focus (no curriculum engine).
model UserTrainingFocus {
  userId             String   @id
  focusSkills        Json
  sessionsRemaining  Int?
  source             String   @default("user")
  updatedAt          DateTime @updatedAt
}

model UserWeaknessProfile {
  id               String         @id @default(cuid())
  userId           String
  skill            SalesSkill
  currentScore     Float
  trendDirection   TrendDirection
  lastSimulationId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, skill])
  @@index([userId])
}

model SimulationSkillScore {
  id             String       @id @default(cuid())
  userId         String?
  conversationId String
  skill          SalesSkill
  score          Int
  reasoning      String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, skill])
  @@index([userId])
}

model SimulationEvaluationSummary {
  id                 String       @id @default(cuid())
  userId             String?
  conversationId     String       @unique
  questionCount      Int
  avgMessageLength   Float
  talkRatio          Float
  weaknesses         Json
  recommendedTips    Json
  rawEvaluatorOutput Json
  createdAt          DateTime     @default(now())
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Auth.js (NextAuth) + ThreadNotion account metadata ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          AccountRole @default(SALES_REP)
  accounts      Account[]
  sessions      Session[]
  anonymousClaims AnonymousIdentityClaim[]
  billingAccount BillingAccount?
  simulationUsage UserSimulationUsage?

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Pending signup: role applied in Auth.js createUser event when email verifies.
model SignUpIntent {
  id         String      @id @default(cuid())
  email      String
  role       AccountRole
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime    @default(now())

  @@index([email])
}

/// Marks anonymous localStorage UUID as merged into authenticated User.id.
model AnonymousIdentityClaim {
  anonymousUserId String   @id
  authUserId      String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  @@index([authUserId])
}

// ===========================================
// Billing (Stripe subscriptions) - MVP
// ===========================================

enum BillingAccountType {
  USER
  TEAM
}

enum SubscriptionPlanType {
  FREE
  INDIVIDUAL
  TEAM
}

enum SubscriptionSeatBundle {
  NONE
  SEATS_10
  SEATS_25
  SEATS_50
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum EntitlementSubjectType {
  USER
  TEAM
}

enum TokenUsageScopeType {
  USER
  TEAM
}

model BillingAccount {
  id               String             @id @default(cuid())
  type             BillingAccountType
  userId           String?            @unique
  teamId           String?            @unique
  stripeCustomerId String             @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  subscription Subscription?
  invoices     InvoiceRecord[]
  events       BillingEventLog[]

  @@index([type])
  @@index([teamId])
}

model Subscription {
  id                   String                 @id @default(cuid())
  billingAccountId     String                 @unique
  planType             SubscriptionPlanType
  seatBundle           SubscriptionSeatBundle @default(NONE)
  status               SubscriptionStatus     @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                @default(false)
  gracePeriodEndsAt    DateTime?
  stripeSubscriptionId String?                @unique
  stripePriceId        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([stripeSubscriptionId])
}

model InvoiceRecord {
  id               String        @id @default(cuid())
  billingAccountId String
  stripeInvoiceId  String        @unique
  amountDue        Int
  amountPaid       Int
  currency         String
  status           String
  hostedInvoiceUrl String?
  invoicePdfUrl    String?
  issuedAt         DateTime
  createdAt        DateTime      @default(now())

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId])
}

model BillingEventLog {
  id               String        @id @default(cuid())
  billingAccountId String
  type             String
  stripeEventId    String?
  payload          Json?
  createdAt        DateTime      @default(now())

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([billingAccountId])
  @@index([stripeEventId])
}

model Entitlement {
  id                 String                 @id @default(cuid())
  subjectType        EntitlementSubjectType
  subjectId          String
  planType           SubscriptionPlanType
  maxSeats           Int
  dailyTokenLimit    Int
  freeSimulationLimit Int                  @default(5)
  updatedAt          DateTime               @updatedAt

  @@unique([subjectType, subjectId])
  @@index([subjectType, subjectId])
}

model TokenUsageDaily {
  id        String             @id @default(cuid())
  scopeType TokenUsageScopeType
  scopeId   String
  date      DateTime
  tokensUsed BigInt            @default(0)
  updatedAt DateTime           @updatedAt

  @@unique([scopeType, scopeId, date])
  @@index([scopeType, scopeId, date])
}

model UserSimulationUsage {
  userId                 String   @id
  uniqueSimulationsCount Int      @default(0)
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
